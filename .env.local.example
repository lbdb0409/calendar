# Copy this file to .env.local and fill in values.
# The app runs without these (using browser localStorage), but you need them
# to share data across devices and email the weekly summary.

# --- Supabase (sync data across browsers/devices) ---
# Get these from https://supabase.com -> your project -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Resend (send weekly summary email to dad) ---
# Sign up at https://resend.com, create an API key, then paste here.
# Free tier is 100 emails/day — way more than you need.
RESEND_API_KEY=

# The "from" address. With Resend's free tier you can use onboarding@resend.dev
# until you verify your own domain.
SUMMARY_FROM_EMAIL=onboarding@resend.dev
